// 3. This function calls the new report API
// This function calls the new report API
async function fetchRollCallReport() {
    const companyId = reportCompanyFilter.value;
    const companyName = reportCompanyFilter.options[reportCompanyFilter.selectedIndex].text;
    reportOutputContainer.innerHTML = '<p>Generating report...</p>';
    
    try {
        // No change here, the view handles all the new logic
        const response = await fetch(`/api/report/roll-call?company_id=${companyId}`);
        if (!response.ok) throw new Error('Could not fetch report data');
        
        const personnel = await response.json();
        
        // --- THIS SECTION IS UPDATED ---
        
        let tableHTML = `
            <h3>Roll Call Report: ${companyName}</h3>
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Rank</th>
                        <th>Company</th>
                        <th>Attendance</th>
                        <th>Assigned Weapon</th>
                        <th>Weapon Status</th>
                    </tr>
                </thead>
                <tbody>
        `;
        
        let presentCount = 0;
        personnel.forEach(soldier => {
            // Set colors for attendance
            let attendanceColor = '#28a745'; // Green for Present
            if (soldier.attendance_status === 'On Leave') {
                attendanceColor = '#ffc107'; // Yellow for On Leave
            } else {
                presentCount++;
            }

            // Set colors for weapon status
            let weaponColor = '#fff'; // Default
            if (soldier.weapon_status === 'With Soldier') {
                weaponColor = '#28a745'; // Green
            } else if (soldier.weapon_status === 'In-Store') {
                weaponColor = '#45b7e9'; // Blue (from QM)
            } else if (soldier.weapon_status.includes('Other') || soldier.weapon_status === 'In-Repair') {
                weaponColor = '#dc3545'; // Red
            }

            tableHTML += `
                <tr>
                    <td>${soldier.name}</td>
                    <td>${soldier.rank}</td>
                    <td>${soldier.company_name}</td>
                    <td style="color: ${attendanceColor}; font-weight: bold;">${soldier.attendance_status}</td>
                    <td>${soldier.assigned_weapon_sn || 'N/A'}</td>
                    <td style="color: ${weaponColor}; font-weight: bold;">${soldier.weapon_status}</td>
                </tr>
            `;
        });

        tableHTML += '</tbody></table>';
        
        // Update summary
        tableHTML = `
            <h3>Roll Call Report: ${companyName}</h3>
            <p>Total Personnel: ${personnel.length} | Present: ${presentCount} | On Leave: ${personnel.length - presentCount}</p>
        ` + tableHTML;

        reportOutputContainer.innerHTML = tableHTML;
        // --- END OF UPDATED SECTION ---

    } catch (error) {
        console.error('Error generating report:', error);
        reportOutputContainer.innerHTML = '<p style="color: #dc3545;">Error: Could not load report.</p>';
    }
}
        
// 5. Update the Download PDF function
// REPLACE your old function with this one
function downloadReportAsPDF() {
    
    // 1. Get the element to print
    const element = document.getElementById('report-output-container');
    const table = element.querySelector('table');

    if (!table) {
        alert('Please generate a report first before downloading.');
        return;
    }

    const filterText = reportCompanyFilter.options[reportCompanyFilter.selectedIndex].text;
    const filename = `RollCall_${filterText.replace(/\s+/g, '_')}.pdf`;

    const options = {
        margin:       [0.5, 0.5, 0.5, 0.5],
        filename:     filename,
        image:        { type: 'jpeg', quality: 0.98 },
        html2canvas:  { scale: 2 },
        jsPDF:        { unit: 'in', format: 'a4', orientation: 'landscape' }
    };

    // --- THIS IS THE FIX ---
    
    // 2. Add the 'pdf-export' class to force black text
    element.classList.add('pdf-export');
    
    // 3. Run the PDF generator
    html2pdf().from(element).set(options).save().then(() => {
        
        // 4. IMPORTANT: Remove the class after the PDF is saved
        //    so your website looks normal again.
        element.classList.remove('pdf-export');
        
    }).catch((err) => {
        // 5. Also remove the class if an error happens
        console.error('PDF generation failed:', err);
        element.classList.remove('pdf-export');
    });
}




    // --- 8. URL CLEANING SCRIPT (No changes, this is correct) ---
    const url = new URL(window.location);
    if (url.searchParams.has('success') || url.searchParams.has('error')) {
        const cleanPath = window.location.pathname;
        window.history.replaceState({}, document.title, cleanPath);
    }
</script>

