<script>
    // --- 1. ALL FUNCTION DEFINITIONS ---
    // These must be defined first, so they can be called by other scripts.

    // Handles switching between sections
    function showSection(sectionId, element) {
        document.querySelectorAll('.module-section').forEach(sec => {
            sec.style.display = 'none';
        });
        document.getElementById(sectionId).style.display = 'block';
        
        document.querySelectorAll('.sidebar ul li').forEach(btn => {
            btn.classList.remove('active');
        });
        
        if (element) {
            element.classList.add('active');
        }
    }

    // Opens and populates the "Edit Stock" modal
    async function editStockItem(stockId) { // <-- Now accepts stockId
    try {
        // UPDATED: Call API with stock_id
        const response = await fetch(`/api/stock-item/${stockId}`);
        if (!response.ok) throw new Error('Could not fetch stock item');
        
        const item = await response.json();
        
        // Populate the modal form
        document.getElementById('edit-item-name').value = item.item_name;
        // UPDATED: Use the new html_expiry_date field
        document.getElementById('edit-expiry-date').value = item.html_expiry_date; 
        document.getElementById('edit-low-stock').value = item.low_stock_threshold;
        document.getElementById('edit-quantity').value = item.quantity_kg; 
        
        // UPDATED: Set the form's action URL
        editStockForm.action = `/qm/update-stock/${stockId}`;
        
        editStockModal.style.display = 'flex';
        
    } catch (error) {
        console.error("Error fetching stock item:", error);
        alert('Error: Could not load item data.');
    }
}

