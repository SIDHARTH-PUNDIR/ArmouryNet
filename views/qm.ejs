    // Closes the "Edit Vehicle" modal
    function closeVehicleModal() {
        editVehicleModal.style.display = 'none';    
    }

    // Closes the "Edit Fuel" modal
    function closeFuelModal() {
        editFuelModal.style.display = 'none';
    }

    // Closes the "Edit Ammo" modal
    function closeAmmoModal() {
        editAmmoModal.style.display = 'none';
    }

    // Closes the "Edit Stock" modal
    function closeModal() {
        editStockModal.style.display = 'none';
    }

    // Closes the "Edit Weapon" modal
    function closeWeaponModal() {
        editWeaponModal.style.display = 'none';
    }

    // Closes the "Edit Ammo" modal
    function closeAmmoModal() {
        editAmmoModal.style.display = 'none';
    }

    // Rebuilds the company-level rations table
    function updateCompanyStockTable(companyId) {
        const companyStockTableBody = document.getElementById('company-stock-table-body');
        companyStockTableBody.innerHTML = ''; // Clear the table

        const filteredRations = allCompanyRations.filter(ration => ration.assigned_company_id == companyId);

        if (filteredRations.length === 0) {
            companyStockTableBody.innerHTML = '<tr><td colspan="5" style="text-align: center;">No stock found for this company.</td></tr>';
            return;
        }

        filteredRations.forEach(ration => {
            const row = `
                <tr>
                    <td>${ration.item_name}</td>
                    <td>${ration.company_name}</td>
                    <td>${ration.quantity_kg}</td>
                    <td>${ration.expiry_date_f || 'N/A'}</td>
                    <td>
                        <a href="/qm/revert-stock/${ration.ration_id}" 
                       style="color: #dc3545; text-decoration: none;" 
                       onclick="return confirm('Are you sure?')">Revert</a>
                    </td>
                </tr>
            `;
            companyStockTableBody.innerHTML += row;
        });
    }

    // --- 2. GLOBAL VARIABLES ---
    // These must be defined *after* the HTML, so they are inside the 'load' event.
    
    let allCompanyRations;
    let companyFilterSelect;
    let editStockModal;
    let editStockForm;
    let editWeaponModal;
    let editWeaponForm;
    let editAmmoModal;
    let editAmmoForm;
    let editFuelModal;
    let editFuelForm;
    let editVehicleModal;
    let editVehicleForm;

    // --- 3. PAGE LOAD EVENT LISTENER ---
    // This runs all the code that needs to find elements on the page.
    window.addEventListener("load", () => {
        
        // Fade-in logic
        document.body.style.opacity = 0;
        document.body.style.transition = "opacity 1.2s ease-in-out";
        document.body.style.opacity = 1;

        // URL-cleaning logic
        const url = new URL(window.location);
        if (url.searchParams.has('success') || url.searchParams.has('error')) {
            const cleanPath = window.location.pathname;
            window.history.replaceState({}, document.title, cleanPath);
        }

        // Rations Filter logic
        allCompanyRations = <%- JSON.stringify(companyRations) %>;
        companyFilterSelect = document.getElementById('company_id');
        
        companyFilterSelect.addEventListener('change', (e) => {
            updateCompanyStockTable(e.target.value);
        });
        
        // Run the filter once on load
        updateCompanyStockTable(companyFilterSelect.value);

        // Stock Edit Modal logic
        editStockModal = document.getElementById('edit-stock-modal');
        editStockForm = document.getElementById('edit-stock-form');
        
        // Weapon Edit Modal logic
        editWeaponModal = document.getElementById('edit-weapon-modal');
        editWeaponForm = document.getElementById('edit-weapon-form');

        // Ammo Edit Modal logic
        editAmmoModal = document.getElementById('edit-ammo-modal');
        editAmmoForm = document.getElementById('edit-ammo-form');

        // Fuel Edit Modal logic
        editFuelModal = document.getElementById('edit-fuel-modal');
        editFuelForm = document.getElementById('edit-fuel-form');


        // Vehicle Edit Modal logic
        editVehicleModal = document.getElementById('edit-vehicle-modal');
        editVehicleForm = document.getElementById('edit-vehicle-form');
    
        // main click handler to close EITHER modal
        window.onclick = function(event) {
        if (event.target == editStockModal) {
            closeModal();
        }
        if (event.target == editWeaponModal) { 
            closeWeaponModal();
        }
        if (event.target == editAmmoModal) {
            closeAmmoModal();
        }
        if (event.target == editFuelModal) {
            closeFuelModal();
        }
        if (event.target == editVehicleModal) {
            closeVehicleModal();
        }
    }
    });


// --- QM REPORTS SCRIPT ---

// 1. Get references to the report elements
const generateReportBtn = document.getElementById('generate-report-btn');
const downloadPdfBtn = document.getElementById('download-pdf-btn');
const reportOutputContainer = document.getElementById('report-output-container');
const reportTypeSelect = document.getElementById('report-type-select');

// 2. Add listener to the "Generate" button
if (generateReportBtn) {
    generateReportBtn.addEventListener('click', () => {
        fetchQMReport();
    });
}

if (downloadPdfBtn) {
    downloadPdfBtn.addEventListener('click', () => {
        downloadReportAsPDF();
    });
}

// 3. This function fetches the report data from the API
async function fetchQMReport() {
    const reportType = reportTypeSelect.value;
    reportOutputContainer.innerHTML = '<p>Generating report...</p>';
    
    try {
        const response = await fetch(`/api/qm-report?type=${reportType}`);
        if (!response.ok) throw new Error('Could not fetch report data');
        
        const result = await response.json();
        
        // 4. Build the HTML for the report
        buildReportTable(result.reportType, result.data);

    } catch (error) {
        console.error('Error generating report:', error);
        reportOutputContainer.innerHTML = '<p style="color: #dc3545;">Error: Could not load report.</p>';
    }
}

// 5. This helper function builds the correct table for each report
function buildReportTable(type, data) {
    let tableHTML = '';
    
    if (type === 'stock') {
        tableHTML = `<h3>Full Battalion Stock Report</h3>`;
        
        // Weapons Table
        tableHTML += '<h4>Weapons</h4><table><thead><tr><th>Serial No.</th><th>Type</th><th>Model</th><th>Status</th></tr></thead><tbody>';
        data.weapons.forEach(item => {
            tableHTML += `<tr><td>${item.serial_number}</td><td>${item.type}</td><td>${item.model}</td><td>${item.status}</td></tr>`;
        });
        tableHTML += '</tbody></table>';

        // Ammunition Table
        tableHTML += '<h4 style="margin-top: 20px;">Ammunition</h4><table><thead><tr><th>Type</th><th>Lot</th><th>Quantity</th><th>Expiry</th></tr></thead><tbody>';
        data.ammo.forEach(item => {
            tableHTML += `<tr><td>${item.ammo_type}</td><td>${item.lot_number}</td><td>${item.quantity}</td><td>${item.expiry_date_f || 'N/A'}</td></tr>`;
        });
        tableHTML += '</tbody></table>';

        // Rations Table
        tableHTML += '<h4 style="margin-top: 20px;">Battalion Rations</h4><table><thead><tr><th>Item</th><th>Lot</th><th>Quantity (kg)</th><th>Expiry</th></tr></thead><tbody>';
        data.rations.forEach(item => {
            tableHTML += `<tr><td>${item.item_name}</td><td>${item.lot_number}</td><td>${item.quantity_kg}</td><td>${item.expiry_date_f || 'N/A'}</td></tr>`;
        });
        tableHTML += '</tbody></table>';

        // Fuel Table
        tableHTML += '<h4 style="margin-top: 20px;">Fuel</h4><table><thead><tr><th>Type</th><th>Quantity (Liters)</th></tr></thead><tbody>';
        data.fuel.forEach(item => {
            tableHTML += `<tr><td>${item.fuel_type}</td><td>${item.quantity_liters}</td></tr>`;
        });
        tableHTML += '</tbody></table>';
        
    }
    else if (type === 'distribution_log') {
        tableHTML = `<h3>Ration Distribution Log</h3>`;
        tableHTML += '<table><thead><tr><th>Date</th><th>Item</th><th>Lot</th><th>Company</th><th>Action</th><th>Qty</th></tr></thead><tbody>';
        
        if (data.length > 0) {
            data.forEach(log => {
                let color = log.transaction_type === 'Received_from_QM' ? '#28a745' : '#dc3545';
                let actionName = log.transaction_type.replace(/_/g, ' ');
                
                tableHTML += `<tr>
                                <td>${log.date_f}</td>
                                <td>${log.item_name}</td>
                                <td>${log.lot_number}</td>
                                <td>${log.company_name}</td>
                                <td>${actionName}</td>
                                <td style="font-weight:bold; color:${color}">
                                    ${log.quantity_change > 0 ? '+' : ''}${log.quantity_change}
                                </td>
                              </tr>`;
            });
        }else {
            tableHTML += '<tr><td colspan="6" style="text-align: center;">No distribution records found.</td></tr>';
        }
        tableHTML += '</tbody></table>';
        } else if (type === 'alerts') {
        tableHTML = `<h3>Active Stock & Maintenance Alerts</h3>`;
        tableHTML += '<table><thead><tr><th>Alert Type</th><th>Message</th><th>Date</th></tr></thead><tbody>';
        if (data.length > 0) {
            data.forEach(alert => {
                tableHTML += `<tr style="color: ${alert.alert_type === 'Expiry' ? '#dc3545' : '#ffc107'};">
                                <td>${alert.alert_type}</td>
                                <td>${alert.message}</td>
                                <td>${alert.alert_date_f}</td>
                              </tr>`;
            });
        } else {
            tableHTML += '<tr><td colspan="3" style="text-align: center;">No active alerts.</td></tr>';
        }
        tableHTML += '</tbody></table>';
    }
    
    reportOutputContainer.innerHTML = tableHTML;
}

// 6. This is your PDF Download function, it will print the generated report
if (downloadPdfBtn) {
    downloadPdfBtn.addEventListener('click', () => {
        const element = document.getElementById('report-output-container');
        if (!element.querySelector('table')) {
            alert('Please generate a report first before downloading.');
            return;
        }
        
        const reportName = reportTypeSelect.options[reportTypeSelect.selectedIndex].text.replace(/\s+/g, '_');
        const filename = `${reportName}.pdf`;

        const options = {
            margin:       [0.5, 0.5, 0.5, 0.5],
            filename:     filename,
            image:        { type: 'jpeg', quality: 0.98 },
            html2canvas:  { scale: 2 },
            jsPDF:        { unit: 'in', format: 'a4', orientation: 'portrait' }
        };

        // Add the 'pdf-export' class to force black text
        element.classList.add('pdf-export');
        
        html2pdf().from(element).set(options).save().then(() => {
            // Remove the class after the PDF is saved
            element.classList.remove('pdf-export');
        }).catch((err) => {
            console.error('PDF generation failed:', err);
            element.classList.remove('pdf-export');
        });
    });
}





</script>

